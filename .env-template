template for hvilke miljøvariabler som skal brukes. Kopier feltene under i en ".env.local" fil.

NEXT_PUBLIC_ENVIRONMENT="localhost"
BEHANDLING_API_BASE_URL="http://localhost:8080"
BEHANDLING_API_SCOPE="dev-gcp:aap:behandlingsflyt"

MELDEKORT_API_BASE_URL="http://localhost:8087"
MELDEKORT_API_SCOPE="dev-gcp:aap:meldekort-backend"

OPPGAVE_API_BASE_URL="http://localhost:8084/"
OPPGAVE_API_SCOPE="dev-gcp:aap:oppgave"

DOKUMENTINNHENTING_API_BASE_URL="http://localhost:8082"
DOKUMENTINNHENTING_API_SCOPE="dokumentinnhenting"

POSTMOTTAK_API_BASE_URL="http://localhost:8070"
POSTMOTTAK_API_SCOPE="dev-gcp:aap:postmottak-backend"

BREV_API_BASE_URL="http://localhost:8082"
BREV_API_SCOPE="dev-gcp:aap:brev-backend"
